{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "ecommerce": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": { "outputPath": "dist", "index": "src/index.html", "main": "src/main.ts", "polyfills": ["zone.js"], "styles": ["src/styles.css"], "tsConfig": "tsconfig.json" },
          "configurations": { "production": { "budgets": [{"type":"initial","maximumWarning":"500kb","maximumError":"1mb"}] } }
        },
        "serve": { "builder": "@angular-devkit/build-angular:dev-server", "configurations": { "production": { "buildTarget": "ecommerce:build:production" } } }
      }
    }
  }
}
